{
  "description": "Auto-format Go files with gofmt after write/edit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(**/*.go)",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gofmt.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/*.go)",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gofmt.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
