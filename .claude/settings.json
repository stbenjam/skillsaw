{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skillsaw/pre-commit.sh",
            "if": "Bash(git commit*)"
          }
        ],
        "_apm_source": "skillsaw"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skillsaw/pre-push.sh",
            "if": "Bash(git push*--force*)"
          }
        ],
        "_apm_source": "skillsaw"
      }
    ]
  }
}
