{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "if": "command.startsWith('git push') && command.includes('--force')",
            "type": "command",
            "command": ".github/hooks/scripts/skillsaw/pre-push.sh"
          }
        ]
      }
    ]
  }
}
