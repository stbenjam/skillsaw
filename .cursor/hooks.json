{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "if": "command.startsWith('git commit')",
            "type": "command",
            "command": ".cursor/hooks/skillsaw/pre-commit.sh"
          }
        ],
        "_apm_source": "skillsaw"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "if": "command.startsWith('git push') && command.includes('--force')",
            "type": "command",
            "command": ".cursor/hooks/skillsaw/pre-push.sh"
          }
        ],
        "_apm_source": "skillsaw"
      }
    ]
  }
}
